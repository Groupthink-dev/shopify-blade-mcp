{
  "name": "shopify-blade-mcp",
  "version": "0.1.0",
  "description": "Shopify Admin API MCP Server — 44 tools for products, orders, customers, inventory, collections, fulfillment, discounts, metafields, webhooks, and analytics via GraphQL",
  "author": "Piers",
  "license": "MIT",
  "runtime": "python",
  "entry_point": "shopify-blade-mcp",
  "environment_variables": {
    "SHOPIFY_STORE_DOMAIN": "Shopify store domain (required, e.g., my-store.myshopify.com)",
    "SHOPIFY_ACCESS_TOKEN": "Admin API access token (required, shpat_...)",
    "SHOPIFY_API_VERSION": "API version (default: 2025-04)",
    "SHOPIFY_WRITE_ENABLED": "Enable write operations (default: false)",
    "SHOPIFY_WEBHOOK_SECRET": "Webhook signing secret for HMAC verification (optional)",
    "SHOPIFY_MCP_TRANSPORT": "Transport mode: stdio or http (default: stdio)",
    "SHOPIFY_MCP_HOST": "HTTP host (default: 127.0.0.1)",
    "SHOPIFY_MCP_PORT": "HTTP port (default: 8770)",
    "SHOPIFY_MCP_API_TOKEN": "Bearer token for HTTP transport auth (optional)"
  },
  "tools": [
    "shopify_info",
    "shopify_shop",
    "shopify_locations",
    "shopify_products",
    "shopify_product",
    "shopify_create_product",
    "shopify_update_product",
    "shopify_delete_product",
    "shopify_orders",
    "shopify_order",
    "shopify_search_orders",
    "shopify_update_order_note",
    "shopify_add_order_tags",
    "shopify_close_order",
    "shopify_cancel_order",
    "shopify_order_fulfillments",
    "shopify_customers",
    "shopify_customer",
    "shopify_search_customers",
    "shopify_create_customer",
    "shopify_update_customer",
    "shopify_inventory",
    "shopify_adjust_inventory",
    "shopify_set_inventory",
    "shopify_collections",
    "shopify_collection",
    "shopify_create_collection",
    "shopify_collection_add_products",
    "shopify_create_fulfillment",
    "shopify_update_tracking",
    "shopify_discounts",
    "shopify_create_discount",
    "shopify_delete_discount",
    "shopify_metafields",
    "shopify_set_metafield",
    "shopify_delete_metafield",
    "shopify_webhooks",
    "shopify_create_webhook",
    "shopify_delete_webhook",
    "shopify_analytics",
    "shopify_verify_webhook"
  ]
}
