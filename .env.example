# Required
SHOPIFY_STORE_DOMAIN="your-store.myshopify.com"
SHOPIFY_ACCESS_TOKEN="shpat_..."

# Optional — defaults shown
SHOPIFY_API_VERSION="2025-04"
SHOPIFY_WRITE_ENABLED="false"

# HTTP transport (optional — default is stdio)
# SHOPIFY_MCP_TRANSPORT="http"
# SHOPIFY_MCP_HOST="127.0.0.1"
# SHOPIFY_MCP_PORT="8770"
# SHOPIFY_MCP_API_TOKEN="your-bearer-token"

# Webhook verification (optional)
# SHOPIFY_WEBHOOK_SECRET="your-webhook-signing-secret"
